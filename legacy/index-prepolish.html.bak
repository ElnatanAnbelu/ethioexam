/* ============================ STORAGE (defensive) ============================ */
function safeGet(key){ try{ return localStorage.getItem(key); }catch(e){ return null; } }
function safeSet(key,val){ try{ localStorage.setItem(key,val); return true; }catch(e){ return false; } }
function safeRemove(key){ try{ localStorage.removeItem(key); }catch(e){} }

let PROGRESS = { subjects:{}, streak:{ count:0, best:0, lastDay:null } };
let progressCorrupt = false;

function loadProgress(){
  const raw = safeGet(STORAGE.PROGRESS);
  if(raw==null) return;
  try{
    const p = JSON.parse(raw);
    if(!p || typeof p!=="object") throw new Error("bad");
    const out = { subjects:{}, streak:{ count:0, best:0, lastDay:null } };
    if(p.subjects && typeof p.subjects==="object"){
      for(const sid of Object.keys(p.subjects)){
        const s = p.subjects[sid];
        if(!s || typeof s!=="object") continue;
        const units = {};
        if(s.units && typeof s.units==="object"){
          for(const uid of Object.keys(s.units)){
            const u = s.units[uid];
            if(u && typeof u==="object" && Number.isFinite(u.answered) && Number.isFinite(u.correct)){
              units[uid] = { answered:Math.max(0,u.answered|0), correct:Math.max(0,u.correct|0) };
            }
          }
        }
        out.subjects[sid] = { units };
      }
    }
    if(p.streak && typeof p.streak==="object"){
      out.streak.count = Number.isFinite(p.streak.count)?Math.max(0,p.streak.count|0):0;
      out.streak.best = Number.isFinite(p.streak.best)?Math.max(0,p.streak.best|0):0;
      out.streak.lastDay = (typeof p.streak.lastDay==="string")?p.streak.lastDay:null;
    }
    PROGRESS = out;
  }catch(e){
    progressCorrupt = true;
    safeRemove(STORAGE.PROGRESS);
    PROGRESS = { subjects:{}, streak:{ count:0, best:0, lastDay:null } };
  }
}
function saveProgress(){ return safeSet(STORAGE.PROGRESS, JSON.stringify(PROGRESS)); }

function todayStr(){ const d=new Date(); return d.getFullYear()+"-"+(d.getMonth()+1)+"-"+d.getDate(); }
function bumpDayStreak(){
  const t = todayStr();
  const s = PROGRESS.streak;
  if(s.lastDay===t) return;
  if(s.lastDay){
    const prev = new Date(s.lastDay); const now = new Date(t);
    const diff = Math.round((now-prev)/86400000);
    s.count = (diff===1) ? s.count+1 : 1;
  } else { s.count = 1; }
  s.lastDay = t;
  if(s.count>s.best) s.best = s.count;
}

function recordAnswer(subjectId, unit, isCorrect){
  if(!PROGRESS.subjects[subjectId]) PROGRESS.subjects[subjectId] = { units:{} };
  const su = PROGRESS.subjects[subjectId].units;
  if(!su[unit]) su[unit] = { answered:0, correct:0 };
  su[unit].answered++;
  if(isCorrect) su[unit].correct++;
}
function subjectStats(subjectId){
  const s = PROGRESS.subjects[subjectId];
  let answered=0, correct=0;
  if(s){ for(const u of Object.values(s.units)){ answered+=u.answered; correct+=u.correct; } }
  return { answered, correct, accuracy: answered? Math.round(correct/answered*100):0 };
}
function overallStats(){
  let answered=0, correct=0;
  for(const sid of Object.keys(PROGRESS.subjects)){
    const st = subjectStats(sid); answered+=st.answered; correct+=st.correct;
  }
  return { answered, correct, accuracy: answered? Math.round(correct/answered*100):0 };
}

/* ============================ THEME ============================ */
let themePref = "system";
let mq = null;
function resolveTheme(){
  if(themePref==="light"||themePref==="dark") return themePref;
  return (mq && mq.matches) ? "dark" : "light";
}
function applyTheme(){ document.documentElement.dataset.theme = resolveTheme(); }
function initTheme(){
  try{ mq = window.matchMedia("(prefers-color-scheme: dark)"); }catch(e){ mq=null; }
  const stored = safeGet(STORAGE.THEME);
  themePref = (stored==="light"||stored==="dark"||stored==="system") ? stored : "system";
  applyTheme();
  if(mq){
    const handler = ()=>{ if(themePref==="system") applyTheme(); };
    if(mq.addEventListener) mq.addEventListener("change",handler);
    else if(mq.addListener) mq.addListener(handler);
  }
}
function setTheme(pref){ themePref=pref; safeSet(STORAGE.THEME,pref); applyTheme(); }

/* ============================ AI PROVIDER + KEY ============================ */
function getProvider(){
  const p = safeGet(STORAGE.PROVIDER);
  return (p==="groq"||p==="gemini") ? p : DEFAULT_PROVIDER;
}
function setProvider(p){
  const v = (p==="groq"||p==="gemini") ? p : DEFAULT_PROVIDER;
  safeSet(STORAGE.PROVIDER, v);
  return v;
}
// Key for the given provider (defaults to the current provider). Each provider stores its own key.
function getKey(provider){
  const prov = PROVIDERS[provider] || PROVIDERS[getProvider()];
  const k = safeGet(prov.storeKey);
  return (typeof k==="string"&&k.trim())?k.trim():null;
}
function hasKey(provider){ return !!getKey(provider); }

/* ============================ DOM HELPERS ============================ */
const $ = id=>document.getElementById(id);
const app = $("app");
function el(tag, attrs, children){
  const n = document.createElement(tag);
  if(attrs){ for(const k of Object.keys(attrs)){
    const v = attrs[k];
    if(v==null||v===false) continue;
    if(k==="class") n.className=v;
    else if(k==="text") n.textContent=v;
    else if(k==="html") n.innerHTML=v; // ONLY trusted literals (icons)
    else if(k.startsWith("on")&&typeof v==="function") n.addEventListener(k.slice(2).toLowerCase(),v);
    else if(k==="dataset"){ for(const dk of Object.keys(v)) n.dataset[dk]=v[dk]; }
    else if(v===true) n.setAttribute(k,"");
    else n.setAttribute(k,v);
  }}
  if(children!=null){
    const arr = Array.isArray(children)?children:[children];
    for(const c of arr){ if(c==null) continue; n.append(typeof c==="string"?document.createTextNode(c):c); }
  }
  return n;
}
function clear(node){ while(node.firstChild) node.removeChild(node.firstChild); }

