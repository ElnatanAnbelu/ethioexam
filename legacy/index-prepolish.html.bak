};
function subjectGlyph(accent){
  const g = {
    physics:'<circle cx="12" cy="12" r="2.2"/><ellipse cx="12" cy="12" rx="9" ry="3.6"/><ellipse cx="12" cy="12" rx="9" ry="3.6" transform="rotate(60 12 12)"/><ellipse cx="12" cy="12" rx="9" ry="3.6" transform="rotate(120 12 12)"/>',
    chemistry:'<path d="M9 3v6l-5 8a2 2 0 0 0 1.7 3h12.6A2 2 0 0 0 20 17l-5-8V3"/><line x1="8" y1="3" x2="16" y2="3"/><line x1="7" y1="14" x2="17" y2="14"/>',
    biology:'<path d="M5 3c0 6 14 6 14 18M19 3C19 9 5 9 5 21"/><line x1="7" y1="6" x2="17" y2="6"/><line x1="6" y1="12" x2="18" y2="12"/><line x1="7" y1="18" x2="17" y2="18"/>',
    math:'<line x1="5" y1="9" x2="11" y2="9"/><line x1="5" y1="15" x2="11" y2="15"/><line x1="14" y1="7" x2="20" y2="7"/><line x1="17" y1="4" x2="17" y2="10"/><line x1="14" y1="17" x2="20" y2="17"/><line x1="14" y1="15" x2="20" y2="19"/><line x1="20" y1="15" x2="14" y2="19"/>',
    english:'<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>',
    sat:'<path d="M12 2 4 6v6c0 5 3.5 8 8 10 4.5-2 8-5 8-10V6z"/><polyline points="9 12 11 14 15 10"/>',
  }[accent] || '';
  return '<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">'+g+'</svg>';
}

/* ============================ BANK QUERIES ============================ */
function isValidQ(q){
  return q && typeof q==="object" && typeof q.question==="string" && q.options && typeof q.options==="object" &&
    typeof q.options.A==="string" && typeof q.options.B==="string" && typeof q.options.C==="string" && typeof q.options.D==="string" &&
    ["A","B","C","D"].includes(q.correct) && typeof q.explanation==="string";
}
function bankFor(subjectId){ return CURATED_BANK.filter(q=>q && q.subject===subjectId && isValidQ(q)); }
function unitsFor(subjectId){
  const sub = SUBJECT_BY_ID[subjectId];
  if(sub && sub.source==="ai") return AI_UNITS[subjectId] || [];
  const seen = []; const set = new Set();
  for(const q of bankFor(subjectId)){ if(q.unit && !set.has(q.unit)){ set.add(q.unit); seen.push(q.unit); } }
  return seen;
}
// Live per-(grade,unit) question counts for a curated subject, keyed "g|unit".
function unitCounts(subjectId){
  const counts = {};
  for(const q of bankFor(subjectId)){ const k=q.grade+"|"+q.unit; counts[k]=(counts[k]||0)+1; }
  return counts;
}
// Grade a curated unit belongs to, inferred from its questions (units are grade-unique here).
function impliedGradeOf(subjectId, unit){
  for(const q of bankFor(subjectId)){ if(q.unit===unit) return q.grade; }
  return null;
}
function shuffle(arr){ const a=arr.slice(); for(let i=a.length-1;i>0;i--){ const j=Math.floor(Math.random()*(i+1)); [a[i],a[j]]=[a[j],a[i]]; } return a; }
// grade: a number (9-12) or "all"/null. The grade filter only applies for "All units";
// a specific unit already constrains the grade, so grade is ignored when unit is set.
function pickCurated(subjectId, unit, difficulty, cap, grade){
  let pool = bankFor(subjectId);
  if(unit && unit!=="__all__"){ pool = pool.filter(q=>q.unit===unit); }
  else if(grade && grade!=="all"){ const g=+grade; pool = pool.filter(q=>q.grade===g); }
  if(difficulty) pool = pool.filter(q=>q.difficulty===difficulty);
  pool = shuffle(pool);
  if(cap && pool.length>cap) pool = pool.slice(0,cap);
  return pool;
}
function pickCuratedMock(subjectId, count){
  let pool = bankFor(subjectId);
  pool = shuffle(pool);
  return { questions: pool.slice(0,count), short: pool.length<count, available: pool.length };
}

/* ============================ AI GENERATION ============================ */
function stripFences(t){
  let s = String(t).trim();
  s = s.replace(/^```(?:json)?\s*/i,"").replace(/\s*```$/,"");
  return s.trim();
}
// HTTP status -> error kind. Works for both Gemini and Groq (both use 401/403 for bad key, 429 for rate limit, 404 for missing model).
function classifyHttp(status){
  if(status===401||status===403) return "key";
  if(status===404) return "model";
  if(status===429) return "rate";
  return "generic";
}
// Provider-neutral error copy — reads correctly for Groq or Gemini.
const AI_ERR = {
  nokey:"Add a free AI key in Settings to unlock unlimited AI questions.",
  network:"Couldn't reach the AI provider. Check your internet connection and try again.",
  parse:"The AI sent something we couldn't read. Try again, or use the curated questions.",
  key:"That key didn't work. Check it in Settings and try again.",
  model:"AI questions are temporarily unavailable. The curated bank still works offline.",
  rate:"Too many requests right now. Wait a moment and try again.",
  generic:"Something went wrong generating questions. The curated bank still works offline.",
};
function aiBadgeKind(subjectId){
  return SUBJECT_BY_ID[subjectId].source==="ai" ? "ai" : "verify";
}
function buildPrompt(subjectId, unit, difficulty, count){
  const unitTxt = (unit && unit!=="__all__") ? unit : "any high-weight unit for this subject";
  const diffDesc = {
    easy:"single-step recall or one-line substitution",
    medium:"two-step reasoning or one standard formula applied once",
    hard:"multi-step, combining two concepts or careful algebra",
    impossible:"olympiad-adjacent multi-concept synthesis with careful traps, still one defensible answer",
  }[difficulty] || "standard";
  return [
    "You are an expert item-writer for the Ethiopian Grade 12 (ESSLCE/EUEE) national exam.",
    "Write "+count+" multiple-choice question(s) for the subject \""+subjectId+"\", unit: "+unitTxt+".",
    "Difficulty tier: "+difficulty+" ("+diffDesc+").",
    "Context: Ethiopian Grade 12 Natural Science / aptitude curriculum.",
    "Each question must have EXACTLY four options keyed A, B, C, D, all non-empty and distinct, with EXACTLY one correct answer, and a worked 1-2 sentence explanation of why it is correct.",
    "Return STRICT JSON ONLY, no markdown, no code fences, no prose. Output a JSON object with a \"questions\" array of objects with this exact shape:",
    '{"questions":[{"question":"...","options":{"A":"...","B":"...","C":"...","D":"..."},"correct":"A","explanation":"..."}]}',
    "Return exactly "+count+" object(s) in the \"questions\" array.",
  ].join("\n");
}
// Normalize any AI JSON (bare array, {questions:[...]} wrapper, or a single object) into validated, schema-shaped questions.
function normalizeAIItems(parsed, subjectId, unit, difficulty){
  let items = Array.isArray(parsed)
    ? parsed
    : (parsed && Array.isArray(parsed.questions) ? parsed.questions
      : (parsed && typeof parsed==="object" ? [parsed] : []));
  const out = [];
  for(const it of items){
    if(isValidQ(it)){
      out.push({
        id:"ai-"+subjectId+"-"+Date.now()+"-"+out.length,
        subject:subjectId, grade:12, unit:(unit&&unit!=="__all__")?unit:(it.unit||"General"),
        difficulty, type:(typeof it.type==="string"?it.type:"conceptual"),
        question:String(it.question), options:{A:String(it.options.A),B:String(it.options.B),C:String(it.options.C),D:String(it.options.D)},
        correct:it.correct, explanation:String(it.explanation), source:"ai",
      });
    }
  }
  return out;
}
function parseError(){ const e=new Error("parse"); e.kind="parse"; return e; }

// GEMINI branch — unchanged behavior: key in ?key= query param, strict-JSON prompt, parse + validate.
async function geminiGenerate(subjectId, unit, difficulty, count){
  const key = getKey("gemini");
  if(!key){ const e=new Error("nokey"); e.kind="nokey"; throw e; }
  const body = {
    contents:[{ parts:[{ text: buildPrompt(subjectId,unit,difficulty,count) }] }],
    generationConfig:{ temperature:0.8, responseMimeType:"application/json" },
  };
  let resp;
  try{
    resp = await fetch(CONFIG.GEMINI_ENDPOINT+"?key="+encodeURIComponent(key), {
      method:"POST", headers:{ "Content-Type":"application/json" }, body:JSON.stringify(body),
    });
  }catch(netErr){ const e=new Error("network"); e.kind="network"; throw e; }
  if(!resp.ok){ const e=new Error("http"); e.kind=classifyHttp(resp.status); throw e; }
  let data;
  try{ data = await resp.json(); }catch(e2){ throw parseError(); }
  let text = "";
  try{ text = data.candidates[0].content.parts.map(p=>p.text||"").join(""); }catch(e3){ text=""; }
  if(!text){ throw parseError(); }
  let parsed;
  try{ parsed = JSON.parse(stripFences(text)); }
  catch(e4){ throw parseError(); }
  const out = normalizeAIItems(parsed, subjectId, unit, difficulty);
  if(out.length===0){ throw parseError(); }
  return out;
}

// GROQ branch — OpenAI-compatible chat completions. Key in Authorization: Bearer header (NEVER in URL).
async function groqGenerate(subjectId, unit, difficulty, count){
  const key = getKey("groq");
  if(!key){ const e=new Error("nokey"); e.kind="nokey"; throw e; }
  const body = {
    model: CONFIG.GROQ_MODEL,
    messages: [
      { role:"system", content:"You are an exam question generator. Respond with STRICT JSON only, no markdown, no code fences." },
      { role:"user", content: buildPrompt(subjectId,unit,difficulty,count) },
    ],
    temperature: 0.7,
    response_format: { type: "json_object" },
  };
  let resp;
  try{
    resp = await fetch(CONFIG.GROQ_ENDPOINT, {
      method:"POST",
      headers:{ "Authorization":"Bearer "+key, "Content-Type":"application/json" },
      body:JSON.stringify(body),
    });
  }catch(netErr){ const e=new Error("network"); e.kind="network"; throw e; }
  if(!resp.ok){ const e=new Error("http"); e.kind=classifyHttp(resp.status); throw e; }
  let data;
  try{ data = await resp.json(); }catch(e2){ throw parseError(); }
  let text = "";
  try{ text = data.choices[0].message.content || ""; }catch(e3){ text=""; }
  if(!text){ throw parseError(); }
  let parsed;
  try{ parsed = JSON.parse(stripFences(text)); }
  catch(e4){ throw parseError(); }
  const out = normalizeAIItems(parsed, subjectId, unit, difficulty);
  if(out.length===0){ throw parseError(); }
  return out;
}

// Provider-aware entry point.
async function aiGenerate(subjectId, unit, difficulty, count){
  return getProvider()==="gemini"
    ? geminiGenerate(subjectId, unit, difficulty, count)
    : groqGenerate(subjectId, unit, difficulty, count);
}
// generate single with one retry
async function aiOneWithRetry(subjectId, unit, difficulty){
  try{ const r = await aiGenerate(subjectId,unit,difficulty,1); return r[0]; }
  catch(e1){
    if(e1.kind==="nokey"||e1.kind==="network"||e1.kind==="key"||e1.kind==="model"||e1.kind==="rate") throw e1;
    try{ const r = await aiGenerate(subjectId,unit,difficulty,1); return r[0]; }
    catch(e2){ throw e2; }
  }
}

/* ============================ TOASTS ============================ */
function toast(msg, type){
  const wrap = $("toastWrap");
  const t = el("div",{ class:"toast"+(type==="error"?" error":""), role: type==="error"?"alert":"status" });
  t.append(el("span",{text:msg}));
  const close = el("button",{ class:"t-close","aria-label":"Dismiss", html:ICONS.close, onclick:()=>dismiss() });
  close.querySelector("svg").setAttribute("width","16"); close.querySelector("svg").setAttribute("height","16");
  t.append(close);
  wrap.append(t);
  let done=false;
  function dismiss(){ if(done) return; done=true; t.remove(); }
  setTimeout(dismiss, CONFIG.TOAST_MS);
}

/* ============================ FOCUS / SCREEN ============================ */
function focusH1(section){
  const h = section.querySelector("h1,[data-h1]");
  if(h){ h.setAttribute("tabindex","-1"); requestAnimationFrame(()=>h.focus()); }
}
function announce(msg, assertive){
  const r = assertive ? $("alertRegion") : $("liveRegion");
  r.textContent=""; requestAnimationFrame(()=>{ r.textContent=msg; });
}

/* ============================ NAV ============================ */
function showView(name){
  STATE.view = name;
  clear(app);
  let section;
  switch(name){
    case "home": section = renderHome(); break;
    case "units": section = renderUnits(); break;
    case "setup": section = renderSetup(); break;
    case "practice": section = renderPractice(); break;
    case "mock": section = renderMock(); break;
    case "summary": section = renderSummary(); break;
    case "review": section = renderReview(); break;
    case "dashboard": section = renderDashboard(); break;
    default: section = renderHome();
  }
  app.append(section);
  focusH1(section);
  window.scrollTo(0,0);
}

/* ============================ COMPONENT BUILDERS ============================ */
function backRow(label, onClick){
  return el("div",{class:"back-row"},[
    (()=>{ const b=el("button",{class:"back-btn","aria-label":label,html:ICONS.chevronLeft,onclick:onClick}); return b; })(),
    el("span",{class:"back-label",text:label}),
  ]);
}
function badge(kind){
  if(kind==="ai") return el("span",{class:"badge badge-ai",text:"AI"});
  if(kind==="verify"){ const b=el("span",{class:"badge badge-verify",title:"AI-generated — double-check this one."}); b.append("AI — verify"); return b; }
  if(kind==="curated") return el("span",{class:"badge badge-curated",text:"Curated"});
  return null;
}

/* ============================ HOME ============================ */
function renderHome(){
  const sec = el("section",{role:"region","aria-label":"Subjects"});
  const head = el("div",{class:"home-head"},[
    el("h1",{class:"home-title",text:"Exam Prep"}),
    el("p",{class:"subtitle",text:"Grade 12 Natural Science"}),
  ]);
  sec.append(head);

  const ov = overallStats();
  const strip = el("button",{class:"progress-strip","aria-label":"View progress",onclick:()=>{ STATE.dashboardSubject=null; showView("dashboard"); }});
  function tile(value, label, muted){
    return el("div",{class:"stat-tile"},[
      el("div",{class:"stat-value"+(muted?" muted":""),text:value}),
      el("div",{class:"stat-label",text:label}),
    ]);
  }
  const any = ov.answered>0;
  strip.append(
    tile(any?String(ov.answered):"0","Answered",!any),
    tile(any?(ov.accuracy+"%"):"—%","Accuracy",!any),
    tile(any?String(PROGRESS.streak.count):"0","Day streak",!any),
  );
  sec.append(strip);
  sec.append(el("button",{class:"view-progress-btn",text:"View progress",onclick:()=>{ STATE.dashboardSubject=null; showView("dashboard"); }}));

  if(!any){
    sec.append(el("p",{class:"home-encourage",text:"Pick a subject to start your first set."}));
  }

  const grid = el("ul",{class:"subject-grid",role:"list"});
  for(const sub of SUBJECTS){
    const st = subjectStats(sub.id);
    const card = el("button",{class:"subject-card",onclick:()=>{ STATE.subject=sub.id; STATE.unit=null; showView("units"); }});
    card.append(el("div",{class:"icon-chip",style:"background:var(--subject-"+sub.accent+"-soft);color:var(--subject-"+sub.accent+")",html:subjectGlyph(sub.accent)}));
    const titleRow = el("div",{class:"card-titlerow"},[ el("span",{class:"card-title",text:sub.name}) ]);
    if(sub.source==="ai") titleRow.append(badge("ai"));
    const statsWrap = el("div");
    if(st.answered>0){
      statsWrap.append(el("div",{class:"card-stat-a",text:st.answered+" answered"}));
      statsWrap.append(el("div",{class:"card-stat-b",text:st.accuracy+"% accuracy"}));
    } else {
      statsWrap.append(el("div",{class:"card-notstarted",text:"Not started yet"}));
    }
    const body = el("div",{},[titleRow, statsWrap]);
    body.style.display="flex"; body.style.flexDirection="column"; body.style.gap="var(--sp-2)";
    card.append(body);
    const li = el("li"); li.style.listStyle="none"; li.append(card); grid.append(li);
  }
  sec.append(grid);
  sec.append(el("p",{class:"home-footer",text:"All progress is saved on this device."}));
  return sec;
}

/* ============================ UNITS ============================ */
function renderUnits(){
  const sub = SUBJECT_BY_ID[STATE.subject];
  const sec = el("section",{role:"region","aria-label":sub.name+" units"});
  sec.append(backRow("Back to subjects",()=>showView("home")));

  const h1 = el("h1",{class:"h1"});
  h1.append(el("span",{class:"title-dot",style:"background:var(--subject-"+sub.accent+")"}));
  h1.append(sub.name);
  sec.append(h1);

  const units = unitsFor(sub.id);
  const isAI = sub.source==="ai";
  const totalQ = isAI ? 0 : bankFor(sub.id).length;
  const subEl = el("p",{class:"subtitle"});
  if(isAI){ subEl.textContent="Questions are generated with AI."; }
  else { subEl.textContent = units.length+" units · "+totalQ+" questions in the bank"; }
  sec.append(subEl);

  if(!isAI && units.length===0){
    sec.append(el("div",{class:"empty-block"},[
      el("p",{class:"eb-body",text:"No questions found for this subject yet."}),
    ]));
    return sec;
  }

  if(isAI && !hasKey()){
    const banner = el("div",{class:"info-banner"});
    banner.append(el("span",{text:"Add a free AI key in Settings to unlock unlimited AI questions. The curated bank works without one."}));
    banner.append(el("button",{class:"ib-btn",text:"Add a key",onclick:()=>openSettings(true)}));
    sec.append(banner);
  }

  const list = el("div",{class:"unit-list"});
  // All units row (every grade)
  const allRow = el("button",{class:"unit-pill unit-all",onclick:()=>{ if(isAI && !hasKey()){ openSettings(true); return; } STATE.unit="__all__"; STATE.grade="all"; showView("setup"); }});
  const allLeft = el("div",{},[ el("div",{class:"ulabel",text:"All units"}), el("div",{class:"usub",text:"Recommended"}) ]);
  allRow.append(allLeft);
  allRow.append(el("span",{class:"check",html:ICONS.check}));
  list.append(allRow);

  if(isAI){
    // AI subjects: flat unit list (no grades, no counts)
    for(const u of units){
      const stat = (PROGRESS.subjects[sub.id]&&PROGRESS.subjects[sub.id].units[u]) || null;
      const pill = el("button",{class:"unit-pill",onclick:()=>{ if(!hasKey()){ openSettings(true); return; } STATE.unit=u; showView("setup"); }});
      pill.append(el("span",{class:"ulabel",text:u}));
      if(stat && stat.answered>0){
        const acc = Math.round(stat.correct/stat.answered*100);
        pill.append(el("span",{class:"acc-chip",text:acc+"%"}));
      }
      list.append(pill);
    }
    sec.append(list);
    return sec;
  }

  // Curated subjects: group official units under grade headings (G9–G12).
  // Every official unit shows, with its live question count; 0-count units are
  // visibly de-emphasized and disabled so coverage gaps are obvious.
  const taxo = UNIT_TAXONOMY[sub.id] || {};
  const counts = unitCounts(sub.id);
  for(const g of [9,10,11,12]){
    const unitNames = taxo[g] || [];
    if(!unitNames.length) continue;
    let gradeTotal = 0;
    for(const u of unitNames) gradeTotal += (counts[g+"|"+u]||0);

    const group = el("div",{class:"unit-group"});
    const head = el("div",{class:"unit-group-head"});
    head.append(el("span",{class:"ugh-grade",text:"Grade "+g}));
    head.append(el("span",{class:"ugh-count",text:gradeTotal+" question"+(gradeTotal===1?"":"s")}));
    group.append(head);

    // "All units in Grade N" — only when the grade has questions
    if(gradeTotal>0){
      const gAll = el("button",{class:"unit-pill",onclick:()=>{ STATE.unit="__all__"; STATE.grade=g; showView("setup"); }});
      gAll.append(el("span",{class:"ulabel",text:"All Grade "+g+" units"}));
      gAll.append(el("span",{class:"acc-chip",text:gradeTotal+" Q"}));
      group.append(gAll);
    }

    for(const u of unitNames){
      const n = counts[g+"|"+u]||0;
      const empty = n===0;
      const stat = (PROGRESS.subjects[sub.id]&&PROGRESS.subjects[sub.id].units[u]) || null;
      const pill = el("button",{class:empty?"unit-pill unit-empty":"unit-pill", disabled:empty?true:null,"aria-disabled":empty?"true":null,
        onclick: empty ? null : (()=>{ STATE.unit=u; STATE.grade=g; showView("setup"); })});
      pill.append(el("span",{class:"ulabel",text:u}));
      const meta = el("span",{class:"unit-meta"});
      if(stat && stat.answered>0 && !empty){
        const acc = Math.round(stat.correct/stat.answered*100);
        meta.append(el("span",{class:"acc-chip",text:acc+"%"}));
      }
      meta.append(el("span",{class:empty?"qcount qcount-zero":"qcount",text:n+" Q"}));
      pill.append(meta);
      group.append(pill);
    }
    list.append(group);
  }
  sec.append(list);
  return sec;
}

/* ============================ SETUP ============================ */
function renderSetup(){
  const sub = SUBJECT_BY_ID[STATE.subject];
  const isAI = sub.source==="ai";
  const sec = el("section",{role:"region","aria-label":"Session setup"});
  sec.append(backRow("Back to units",()=>showView("units")));
  sec.append(el("h1",{class:"h1",text:"Set up your session"}));
  const unitLabel = STATE.unit==="__all__" ? "All units" : STATE.unit;
  sec.append(el("p",{class:"subtitle",text:sub.name+" · "+unitLabel}));

  // DIFFICULTY
  const diffSec = el("div",{class:"setup-section"});
  diffSec.append(el("span",{class:"overline",text:"DIFFICULTY",id:"diffLabel"}));
  const diffRow = el("div",{class:"diff-row",role:"radiogroup","aria-labelledby":"diffLabel"});
  const diffBtns = [];
  DIFFICULTIES.forEach((d)=>{
    const checked = STATE.difficulty===d.id;
    const chip = el("button",{class:"diff-chip",role:"radio","aria-checked":checked?"true":"false",tabindex:checked?"0":"-1"});
    chip.append(el("span",{text:d.label}));
    const dots = el("span",{class:"diff-dots","aria-hidden":"true"});
    for(let i=0;i<4;i++) dots.append(el("i",{class:i<d.dots?"on":""}));
    chip.append(dots);
    chip.addEventListener("click",()=>selectDiff(d.id));
    chip.addEventListener("keydown",e=>{
      if(e.key==="ArrowRight"||e.key==="ArrowDown"){ e.preventDefault(); const i=DIFFICULTIES.findIndex(x=>x.id===STATE.difficulty); selectDiff(DIFFICULTIES[(i+1)%4].id); diffBtns[(i+1)%4].focus(); }
      else if(e.key==="ArrowLeft"||e.key==="ArrowUp"){ e.preventDefault(); const i=DIFFICULTIES.findIndex(x=>x.id===STATE.difficulty); selectDiff(DIFFICULTIES[(i+3)%4].id); diffBtns[(i+3)%4].focus(); }
    });
    diffBtns.push(chip);
    diffRow.append(chip);
  });
  function selectDiff(id){
    STATE.difficulty=id;
    DIFFICULTIES.forEach((d,i)=>{ const on=d.id===id; diffBtns[i].setAttribute("aria-checked",on?"true":"false"); diffBtns[i].setAttribute("tabindex",on?"0":"-1"); });
    refreshStartState();
  }
  diffSec.append(diffRow);
  sec.append(diffSec);

  // GRADE (curated subjects only). When a specific unit is chosen, grade is implied
  // by that unit and locked. With "All units", the selector narrows Free Practice by
  // grade ("All" = every grade). Ignored in Mock mode (mock mixes across grades).
  const specificUnit = STATE.unit && STATE.unit!=="__all__";
  let gradeBtns = [];
  let gradeSec = null;
  if(!isAI){
    gradeSec = el("div",{class:"setup-section"});
    gradeSec.append(el("span",{class:"overline",text:"GRADE",id:"gradeLabel"}));
    if(specificUnit){
      // implied grade: derive from the unit's questions (STATE.grade was set by the picker)
      const impliedG = (STATE.grade && STATE.grade!=="all") ? STATE.grade : impliedGradeOf(sub.id, STATE.unit);
      const lock = el("div",{class:"grade-lock"});
      lock.append(el("span",{text: impliedG ? ("Grade "+impliedG) : "—"}));
      lock.append(el("span",{class:"grade-lock-note",text:"set by this unit"}));
      gradeSec.append(lock);
    } else {
      const gradeRow = el("div",{class:"diff-row grade-row",role:"radiogroup","aria-labelledby":"gradeLabel"});
      const opts = [["all","All"],[9,"9"],[10,"10"],[11,"11"],[12,"12"]];
      opts.forEach(([val,lbl])=>{
        const checked = String(STATE.grade)===String(val);
        const chip = el("button",{class:"diff-chip grade-chip",role:"radio","aria-checked":checked?"true":"false",tabindex:checked?"0":"-1",text:lbl});
        chip.addEventListener("click",()=>selectGrade(val));
        chip.addEventListener("keydown",e=>{
          if(e.key==="ArrowRight"||e.key==="ArrowDown"){ e.preventDefault(); const i=opts.findIndex(o=>String(o[0])===String(STATE.grade)); const ni=(i+1)%opts.length; selectGrade(opts[ni][0]); gradeBtns[ni].focus(); }
          else if(e.key==="ArrowLeft"||e.key==="ArrowUp"){ e.preventDefault(); const i=opts.findIndex(o=>String(o[0])===String(STATE.grade)); const ni=(i+opts.length-1)%opts.length; selectGrade(opts[ni][0]); gradeBtns[ni].focus(); }
        });
        gradeBtns.push(chip);
        gradeRow.append(chip);
      });
      function selectGrade(val){
        STATE.grade=val;
        const opts2=[["all"],[9],[10],[11],[12]];
        gradeBtns.forEach((b,i)=>{ const on=String(opts2[i][0])===String(val); b.setAttribute("aria-checked",on?"true":"false"); b.setAttribute("tabindex",on?"0":"-1"); });
        refreshStartState();
      }
      gradeSec.append(gradeRow);
      gradeSec.append(el("p",{class:"helper",text:"Free Practice only — Mock Exam mixes all grades."}));
    }
    sec.append(gradeSec);
  }

  // MODE
  const modeSec = el("div",{class:"setup-section"});
  modeSec.append(el("span",{class:"overline",text:"MODE",id:"modeLabel"}));
  const modeToggle = el("div",{class:"mode-toggle",role:"radiogroup","aria-labelledby":"modeLabel"});
  const modes = [["practice","Practice"],["mock","Mock Exam"]];
  const modeBtns = [];
  modes.forEach(([id,lbl])=>{
    const checked = STATE.mode===id;
    const seg = el("button",{class:"mode-seg",role:"radio","aria-checked":checked?"true":"false",tabindex:checked?"0":"-1",text:lbl});
    seg.addEventListener("click",()=>selectMode(id));
    seg.addEventListener("keydown",e=>{
      if(["ArrowRight","ArrowDown","ArrowLeft","ArrowUp"].includes(e.key)){ e.preventDefault(); const other=STATE.mode==="practice"?"mock":"practice"; selectMode(other); modeBtns[other==="practice"?0:1].focus(); }
    });
    modeBtns.push(seg); modeToggle.append(seg);
  });
  modeSec.append(modeToggle);
  const modeHelper = el("p",{class:"helper"});
  modeSec.append(modeHelper);
  sec.append(modeSec);

  // AI EXTRA (sciences only)
  let aiSwitch=null;
  if(!isAI){
    const aiSec = el("div",{class:"setup-section"});
    aiSec.append(el("span",{class:"overline",text:"AI EXTRA PRACTICE"}));
    const keyOn = hasKey();
    if(!keyOn) STATE.aiExtra=false;
    const row = el("div",{class:"switch-row"});
    aiSwitch = el("button",{class:"switch",role:"switch","aria-checked":STATE.aiExtra?"true":"false","aria-disabled":keyOn?null:"true","aria-label":"Generate extra questions with AI"});
    aiSwitch.append(el("span",{class:"knob"}));
    const lbl = el("span",{class:"switch-label"},[ "Generate extra questions with AI" ]);
    lbl.append(badge("verify"));
    aiSwitch.addEventListener("click",()=>{ if(!hasKey()) return; STATE.aiExtra=!STATE.aiExtra; aiSwitch.setAttribute("aria-checked",STATE.aiExtra?"true":"false"); });
    row.append(aiSwitch,lbl);
    aiSec.append(row);
    aiSec.append(el("p",{class:"helper",text: keyOn ? "AI questions supplement the curated bank. Always double-check them." : "Add a free AI key in Settings to turn this on."}));
    sec.append(aiSec);
  }

  // ACTIONS
  const actions = el("div",{class:"setup-actions"});
  const noteWrap = el("div");
  const startBtn = el("button",{class:"btn-primary"});
  startBtn.addEventListener("click",onStart);
  actions.append(noteWrap, startBtn);
  sec.append(actions);

  function selectMode(id){
    STATE.mode=id;
    modes.forEach(([m],i)=>{ modeBtns[i].setAttribute("aria-checked",m===id?"true":"false"); modeBtns[i].setAttribute("tabindex",m===id?"0":"-1"); });
    refreshStartState();
  }

  function curatedTierCount(){
    if(isAI) return 1;
    return pickCurated(sub.id, STATE.unit, STATE.difficulty, null, STATE.grade).length;
  }

  function refreshStartState(){
    clear(noteWrap);
    const mock = STATE.mode==="mock";
    // Grade filter is Free-Practice-only; dim it in Mock mode (mock mixes all grades).
    if(gradeSec){ gradeSec.style.opacity = mock ? "0.45" : ""; gradeSec.setAttribute("aria-disabled", mock?"true":"false"); }
    if(mock){ gradeBtns.forEach(b=>{ b.disabled=true; }); }
    else { gradeBtns.forEach(b=>{ b.disabled=false; }); }
    // mode helper
    if(mock){
      const bp = MOCK_BLUEPRINT[sub.id];
      modeHelper.textContent = bp.count+" questions · "+bp.minutes+" min · no feedback until the end.";
    } else {
      modeHelper.textContent = "Instant feedback and an explanation after each question.";
    }
    startBtn.textContent = mock ? "Start mock exam" : "Start practice";

    // AI subject gating
    if(isAI && !hasKey()){
      startBtn.disabled = true;
      const ie = el("div",{class:"inline-error"},[
        el("div",{class:"ie-head"},[ el("span",{html:ICONS.warn,style:"color:var(--danger)"}), el("span",{text:"AI key needed"}) ]),
        el("div",{class:"ie-body",text:"Add a free AI key in Settings to unlock unlimited AI questions."}),
        el("div",{class:"ie-actions"},[ el("button",{class:"btn-secondary",text:"Add a key",onclick:()=>openSettings(true)}) ]),
      ]);
      noteWrap.append(ie);
      return;
    }
    // curated tier emptiness (practice only; mock samples across difficulties)
    if(!isAI && !mock && curatedTierCount()===0){
      startBtn.disabled = true;
      noteWrap.append(el("p",{class:"inline-note",text:"No "+DIFFICULTIES.find(d=>d.id===STATE.difficulty).label+" questions here yet — try another level."}));
      return;
    }
    if(!isAI && mock){
      const avail = pickCuratedMock(sub.id, MOCK_BLUEPRINT[sub.id].count);
      if(avail.available===0){ startBtn.disabled=true; noteWrap.append(el("p",{class:"inline-note",text:"No questions in the bank for this subject yet."})); return; }
    }
    startBtn.disabled = false;
  }

  function onStart(){
    if(STATE.mode==="mock") startMock();
    else startPractice();
  }
  refreshStartState();
  return sec;
}

/* ============================ PRACTICE START ============================ */
function startPractice(){
  const sub = SUBJECT_BY_ID[STATE.subject];
  const isAI = sub.source==="ai";
  STATE.session = {
    type:"practice", subject:sub.id, unit:STATE.unit, difficulty:STATE.difficulty, grade:STATE.grade,
    questions:[], idx:0, answers:[], correct:0, streak:0, bestStreak:0,
    startTime:Date.now(), aiMode:isAI, aiExtra:STATE.aiExtra && !isAI, graded:false, selected:null,
    loading:false, error:null, savedToday:false,
  };
  if(isAI){
    // pure AI practice: generate first question
    STATE.session.questions = [];
    showView("practice");
    generatePracticeQuestion();
  } else if(STATE.aiExtra){
    // curated base + we'll generate AI extras lazily after curated runs; simplest: build curated set; AI generated on demand at the end -> spec: supplement. We mix: curated set, then if exhausted try AI.
    STATE.session.questions = pickCurated(sub.id, STATE.unit, STATE.difficulty, CONFIG.PRACTICE_CAP, STATE.grade);
    STATE.session.aiSupplement = true;
    showView("practice");
  } else {
    STATE.session.questions = pickCurated(sub.id, STATE.unit, STATE.difficulty, CONFIG.PRACTICE_CAP, STATE.grade);
    showView("practice");
  }
}

async function generatePracticeQuestion(){
  const s = STATE.session;
  s.loading = true; s.error=null;
  showView("practice");
  try{
    const q = await aiOneWithRetry(s.subject, s.unit, s.difficulty);
    s.questions.push(q);
    s.loading=false; s.idx = s.questions.length-1; s.graded=false; s.selected=null;
    showView("practice");
  }catch(e){
    s.loading=false;
    s.error = AI_ERR[e.kind] || AI_ERR.generic;
    showView("practice");
  }
}

/* ============================ PRACTICE RENDER ============================ */
function renderPractice(){
  const s = STATE.session;
  const sub = SUBJECT_BY_ID[s.subject];
  const sec = el("section",{role:"region","aria-label":"Practice session"});

  // header
  const total = s.aiMode ? Math.max(s.questions.length,1) : s.questions.length;
  const header = el("div",{class:"session-header"});
  header.append(el("button",{class:"icon-btn","aria-label":"Leave this session",html:ICONS.chevronLeft,onclick:()=>confirmLeavePractice()}));
  const center = el("div",{class:"sh-center"});
  const qnum = s.questions.length ? (s.idx+1) : 0;
  center.append(el("div",{class:"qcount",text:"Q "+qnum+" of "+(s.aiMode?qnum:total)}));
  const pbar = el("div",{class:"pbar","aria-hidden":"true"});
  const pct = total ? Math.round((qnum)/Math.max(total,1)*100) : 0;
  pbar.append(el("div",{class:"fill",style:"width:"+pct+"%"}));
  center.append(pbar);
  header.append(center);
  const stats = el("div",{class:"sh-stats"});
  const scoreEl = el("div",{class:"sh-score","aria-label":s.correct+" correct of "+s.answers.length+" answered"});
  scoreEl.append(el("span",{html:ICONS.check,style:"color:var(--success);width:16px"}));
  const scv = el("span",{class:"mono",text:s.correct+"/"+s.answers.length}); scoreEl.append(scv);
  stats.append(scoreEl);
  if(s.streak>=2){
    const st = el("div",{class:"sh-streak","aria-label":s.streak+" in a row"});
    st.append(el("span",{html:ICONS.flame}));
    st.append(el("span",{class:"mono",text:String(s.streak)}));
    stats.append(st);
  }
  header.append(stats);
  sec.append(header);

  // loading state
  if(s.loading){
    const card = el("div",{class:"qcard"});
    card.append(el("div",{class:"skel skel-line",style:"width:80%"}));
    card.append(el("div",{class:"skel skel-line",style:"width:60%"}));
    for(let i=0;i<4;i++) card.append(el("div",{class:"skel skel-opt"}));
    const ld = el("div",{class:"gen-status"});
    ld.append(el("span",{class:"spinner","aria-hidden":"true"}));
    ld.append(el("span",{class:"gen-msg",text:"Writing a fresh question…"}));
    card.append(ld);
    sec.append(card);
    rotateLoadingMsg(ld.querySelector(".gen-msg"));
    return sec;
  }

  // error state
  if(s.error){
    const card = el("div",{class:"qcard"});
    const ie = el("div",{class:"inline-error"},[
      el("div",{class:"ie-head"},[ el("span",{html:ICONS.warn,style:"color:var(--danger)"}), el("span",{text:"Couldn't generate a question"}) ]),
      el("div",{class:"ie-body",text:s.error}),
    ]);
    const acts = el("div",{class:"ie-actions"});
    acts.append(el("button",{class:"btn-primary",text:"Try again",onclick:()=>{ if(s.aiMode){ generatePracticeQuestion(); } else { s.error=null; showView("practice"); } }}));
    if(!s.aiMode || sub.source!=="ai"){
      // "Use curated instead" only for sciences (which have curated bank)
      if(sub.source!=="ai"){
        acts.append(el("button",{class:"btn-secondary",text:"Use curated instead",onclick:()=>{
          s.aiMode=false; s.error=null;
          if(s.questions.length===0) s.questions = pickCurated(sub.id,s.unit,s.difficulty,CONFIG.PRACTICE_CAP);
          showView("practice");
        }}));
      }
    }
    ie.append(acts);
    card.append(ie);
    sec.append(card);
    return sec;
  }

  // empty
  if(s.questions.length===0){
    const card = el("div",{class:"qcard"});
    card.append(el("div",{class:"empty-block"},[
      el("p",{class:"eb-body",text:"No questions to show here. Try a different unit or difficulty."}),
      el("button",{class:"btn-secondary",text:"Back to setup",onclick:()=>showView("setup")}),
    ]));
    sec.append(card);
    return sec;
  }

  const q = s.questions[s.idx];
  const card = el("div",{class:"qcard"});
  // meta
  const meta = el("div",{class:"qmeta"});
  const unitInfo = el("div",{class:"unit"});
  unitInfo.append(el("span",{class:"dot",style:"background:var(--subject-"+sub.accent+")"}));
  unitInfo.append(el("span",{text:q.unit||"General"}));
  meta.append(unitInfo);
  if(q.source==="ai") meta.append(badge(sub.source==="ai"?"ai":"verify"));
  card.append(meta);

  card.append(el("div",{class:"qtext",text:q.question}));

  const optsWrap = el("div",{class:"options"});
  const optBtns = {};
  ["A","B","C","D"].forEach(letter=>{
    const ob = el("button",{class:"opt","data-letter":letter});
    ob.append(el("span",{class:"ltoken",text:letter}));
    ob.append(el("span",{class:"otext",text:q.options[letter]}));
    ob.append(el("span",{class:"ricon"}));
    ob.append(el("span",{class:"otag"}));
    if(!s.graded){
      ob.setAttribute("aria-pressed","false");
      ob.addEventListener("click",()=>gradeAnswer(letter,q,sub,optBtns,card));
    }
    optBtns[letter]=ob;
    optsWrap.append(ob);
  });
  card.append(optsWrap);

  if(!s.graded){
    card.append(el("p",{class:"prehint",text:"Tap an answer to check it."}));
  } else {
    // re-render graded state
    applyGradedVisual(optBtns, q, s.selected);
    card.append(buildExplanation(q, s.selected===q.correct));
    const nextZone = el("div",{class:"next-zone"});
    const isLast = !s.aiMode && (s.idx>=s.questions.length-1);
    const nb = el("button",{class:"btn-primary",text:isLast?"See results":"Next question",onclick:()=>nextPractice(sub)});
    nextZone.append(nb);
    card.append(nextZone);
    requestAnimationFrame(()=>nb.focus());
  }

  // keyboard A-D / 1-4
  if(!s.graded){
    sec.addEventListener("keydown",function kd(e){
      const k = e.key.toUpperCase();
      let letter=null;
      if(["A","B","C","D"].includes(k)) letter=k;
      else if(["1","2","3","4"].includes(e.key)) letter=["A","B","C","D"][parseInt(e.key,10)-1];
      if(letter && optBtns[letter] && !STATE.session.graded){ gradeAnswer(letter,q,sub,optBtns,card); }
    });
  }

  sec.append(card);
  return sec;
}

function rotateLoadingMsg(node){
  if(!node) return;
  if(window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
  const msgs=["Writing a fresh question…","Thinking through the options…"];
  let i=0;
  const iv=setInterval(()=>{
    if(!document.body.contains(node)){ clearInterval(iv); return; }
    i=(i+1)%msgs.length; node.textContent=msgs[i];
  },2500);
}

function buildExplanation(q, correct){
  const ex = el("div",{class:"explain"+(correct?"":" wrong")});
  ex.append(el("div",{class:"why",text:"Why"}));
  if(q.source==="ai") ex.append(el("div",{class:"ai-note",text:"AI-generated — verify against your notes."}));
  ex.append(el("div",{class:"body",text:q.explanation}));
  return ex;
}
function applyGradedVisual(optBtns, q, selected){
  ["A","B","C","D"].forEach(letter=>{
    const ob = optBtns[letter];
    ob.setAttribute("aria-disabled","true");
    ob.setAttribute("aria-pressed", letter===selected?"true":"false");
    const tag = ob.querySelector(".otag");
    if(letter===q.correct){
      ob.classList.add("correct");
      tag.textContent = (selected!==q.correct) ? "Correct answer" : "";
    } else if(letter===selected){
      ob.classList.add("incorrect");
      tag.textContent = "Your answer";
    } else {
      ob.classList.add("dimmed");
    }
  });
}
function gradeAnswer(letter, q, sub, optBtns, card){
  const s = STATE.session;
  if(s.graded) return;
  s.graded=true; s.selected=letter;
  const correct = letter===q.correct;
  s.answers.push({ q, selected:letter, correct });
  if(correct){ s.correct++; s.streak++; if(s.streak>s.bestStreak) s.bestStreak=s.streak; }
  else { s.streak=0; }
  recordAnswer(s.subject, q.unit||"General", correct);
  bumpDayStreak();
  if(!saveProgress()){ if(!s.savedToday){ s.savedToday=true; toast("Couldn't save this session's progress.","error"); } }

  applyGradedVisual(optBtns, q, letter);
  if(correct){
    const cb = optBtns[q.correct];
    cb.classList.add("pop");
  }
  announce(correct ? "Correct." : "Incorrect. The answer is "+q.correct+".");

  // explanation + next
  card.append(buildExplanation(q, correct));
  const nextZone = el("div",{class:"next-zone"});
  const isLast = !s.aiMode && (s.idx>=s.questions.length-1);
  const nb = el("button",{class:"btn-primary",text:isLast?"See results":"Next question",onclick:()=>nextPractice(sub)});
  nextZone.append(nb);
  card.append(nextZone);

  // update header score/streak live by re-render of just header would be complex; re-render whole view keeps state
  const scoreEl = card.closest("section").querySelector(".sh-score");
  if(scoreEl){ scoreEl.querySelector(".mono").textContent = s.correct+"/"+s.answers.length; scoreEl.setAttribute("aria-label",s.correct+" correct of "+s.answers.length+" answered"); }
  const statsWrap = card.closest("section").querySelector(".sh-stats");
  if(statsWrap){
    let st = statsWrap.querySelector(".sh-streak");
    if(s.streak>=2){
      if(!st){ st=el("div",{class:"sh-streak"}); st.append(el("span",{html:ICONS.flame})); st.append(el("span",{class:"mono"})); statsWrap.append(st); }
      st.setAttribute("aria-label",s.streak+" in a row");
      st.querySelector(".mono").textContent=String(s.streak);
    } else if(st){ st.remove(); }
  }
  requestAnimationFrame(()=>nb.focus());
}
function nextPractice(sub){
  const s = STATE.session;
  if(s.aiMode){
    generatePracticeQuestion();
    return;
  }
  if(s.idx < s.questions.length-1){
    s.idx++; s.graded=false; s.selected=null;
    showView("practice");
  } else {
    finishPracticeSession();
  }
}
function finishPracticeSession(){
  const s = STATE.session;
  if(s.answers.length===0){ showView("setup"); return; }
  showView("summary");
}
function confirmLeavePractice(){
  if(STATE.session && STATE.session.answers.length>0 && (!STATE.session.aiMode ? STATE.session.idx<STATE.session.questions.length : true)){
    openConfirm({ title:"Leave this session?", body:"Your answers so far won't be saved.", confirm:"Leave", cancel:"Stay", danger:true, onConfirm:()=>{ STATE.session=null; showView("home"); } });
  } else {
    STATE.session=null; showView("home");
  }
}

/* ============================ MOCK START ============================ */
function startMock(){
  const sub = SUBJECT_BY_ID[STATE.subject];
  const bp = MOCK_BLUEPRINT[sub.id];
  const isAI = sub.source==="ai";
  STATE.session = {
    type:"mock", subject:sub.id, unit:STATE.unit, difficulty:STATE.difficulty,
    questions:[], idx:0, answers:[], flagged:[], count:bp.count, minutes:bp.minutes,
    remaining:bp.minutes*60, timerId:null, startTime:Date.now(), aiMode:isAI,
    genK:0, genN:bp.count, genError:null, genShort:false, submitted:false,
  };
  if(isAI){
    if(!hasKey()){ openSettings(true); return; }
    showView("mock"); // shows gen screen
    runMockGeneration();
  } else {
    const picked = pickCuratedMock(sub.id, bp.count);
    STATE.session.questions = picked.questions;
    STATE.session.answers = new Array(picked.questions.length).fill(null);
    STATE.session.flagged = new Array(picked.questions.length).fill(false);
    STATE.session.genShort = picked.short;
    if(picked.short) toast("Using all "+picked.questions.length+" available questions for this mock.");
    startMockTimer();
    showView("mock");
  }
}
async function runMockGeneration(){
  const s = STATE.session;
  STATE.genAbort=false;
  s.genError=null;
  showView("mock");
  const diffs=["easy","medium","hard","impossible"];
  for(let i=0;i<s.genN;i++){
    if(STATE.genAbort){ return; }
    const diff = diffs[i % diffs.length];
    let q=null;
    try{ q = await aiOneWithRetry(s.subject, s.unit, diff); }
    catch(e){
      s.genError = { msg: AI_ERR[e.kind]||AI_ERR.generic, k:s.questions.length };
      showView("mock");
      return;
    }
    s.questions.push(q);
    s.genK = s.questions.length;
    updateGenProgress();
  }
  // finalize
  s.answers = new Array(s.questions.length).fill(null);
  s.flagged = new Array(s.questions.length).fill(false);
  s.count = s.questions.length;
  startMockTimer();
  showView("mock");
}
function updateGenProgress(){
  const s = STATE.session;
  const bar = $("genBarFill"); const head=$("genHead");
  if(bar) bar.style.width = Math.round(s.genK/s.genN*100)+"%";
  if(head) head.textContent = "Generating your mock exam… "+s.genK+" of "+s.genN+" questions";
  const pr = $("genProgress");
  if(pr){ pr.setAttribute("aria-valuenow",String(s.genK)); pr.setAttribute("aria-valuetext",s.genK+" of "+s.genN+" generated"); }
}
function startMockTimer(){
  const s = STATE.session;
  if(s.timerId) clearInterval(s.timerId);
  s.timerId = setInterval(()=>{
    if(STATE.view!=="mock" || !STATE.session || STATE.session!==s){ clearInterval(s.timerId); return; }
    s.remaining--;
    updateTimerUI();
    const r=s.remaining;
    if(r===300) announce("Five minutes left.");
    else if(r===60) announce("One minute left.");
    else if(r===30) announce("Thirty seconds left.");
    if(r<=0){ clearInterval(s.timerId); autoSubmitMock(); }
  },1000);
}
function fmtTime(sec){ sec=Math.max(0,sec|0); const m=Math.floor(sec/60); const s=sec%60; return (m<10?"0":"")+m+":"+(s<10?"0":"")+s; }
function updateTimerUI(){
  const s = STATE.session; if(!s) return;
  const tEl=$("mockTimer"); const fEl=$("mockTimerFill");
  if(tEl) tEl.textContent = fmtTime(s.remaining);
  const totalSec = s.minutes*60;
  const pct = Math.max(0, s.remaining/totalSec*100);
  if(fEl) fEl.style.width = pct+"%";
  const low = s.remaining <= totalSec*0.10;
  if(tEl) tEl.classList.toggle("low",low);
  if(fEl) fEl.classList.toggle("low",low);
}

/* ============================ MOCK RENDER ============================ */
function renderMock(){
  const s = STATE.session;
  const sub = SUBJECT_BY_ID[s.subject];
  const sec = el("section",{role:"region","aria-label":"Mock exam"});

  // Generation screen (AI)
  if(s.aiMode && s.questions.length < s.count && !s.genError){
    sec.append(el("h1",{class:"sr-only",text:"Generating mock exam"}));
    const gs = el("div",{class:"gen-screen"});
    gs.append(el("div",{class:"gs-head",id:"genHead",text:"Generating your mock exam… "+s.genK+" of "+s.genN+" questions"}));
    const bar = el("div",{class:"gs-bar",role:"progressbar",id:"genProgress","aria-valuemin":"0","aria-valuemax":String(s.genN),"aria-valuenow":String(s.genK),"aria-valuetext":s.genK+" of "+s.genN+" generated"});
    bar.append(el("div",{class:"fill",id:"genBarFill",style:"width:"+Math.round(s.genK/s.genN*100)+"%"}));
    gs.append(bar);
    gs.append(el("div",{class:"gs-sub",text:"This can take a moment. Keep this screen open."}));
    gs.append(el("button",{class:"btn-secondary",text:"Cancel",style:"max-width:200px;margin:0 auto",onclick:()=>{ STATE.genAbort=true; STATE.session=null; showView("setup"); }}));
    sec.append(gs);
    return sec;
  }
  // Gen error
  if(s.genError){
    sec.append(el("h1",{class:"sr-only",text:"Mock generation problem"}));
    const ie = el("div",{class:"inline-error"},[
      el("div",{class:"ie-head"},[ el("span",{html:ICONS.warn,style:"color:var(--danger)"}), el("span",{text:"Generated "+s.genError.k+" of "+s.genN+" before a problem."}) ]),
      el("div",{class:"ie-body",text:s.genError.msg}),
    ]);
    const acts = el("div",{class:"ie-actions"});
    acts.append(el("button",{class:"btn-primary",text:"Try again",onclick:()=>{ s.questions=[]; s.genK=0; s.genError=null; runMockGeneration(); }}));
    if(s.genError.k >= CONFIG.AI_MOCK_MIN_FALLBACK){
      acts.append(el("button",{class:"btn-secondary",text:"Start with "+s.genError.k+" questions",onclick:()=>{
        s.answers=new Array(s.questions.length).fill(null); s.flagged=new Array(s.questions.length).fill(false);
        s.count=s.questions.length; s.genError=null; startMockTimer(); showView("mock");
      }}));
    }
    acts.append(el("button",{class:"btn-secondary",text:"Cancel",onclick:()=>{ STATE.session=null; showView("setup"); }}));
    ie.append(acts);
    sec.append(ie);
    return sec;
  }

  if(s.questions.length===0){
    sec.append(el("h1",{class:"sr-only",text:"Mock exam"}));
    sec.append(el("div",{class:"empty-block"},[
      el("p",{class:"eb-body",text:"No questions to show here. Try a different unit or difficulty."}),
      el("button",{class:"btn-secondary",text:"Back to setup",onclick:()=>{ STATE.session=null; showView("setup"); }}),
    ]));
    return sec;
  }

  // header
  const header = el("div",{class:"session-header"});
  header.append(el("button",{class:"icon-btn","aria-label":"Leave the exam",html:ICONS.chevronLeft,onclick:()=>confirmLeaveMock()}));
  const tw = el("div",{class:"timer-wrap"});
  tw.append(el("div",{class:"timer"+ (s.remaining<=s.minutes*60*0.1?" low":""),id:"mockTimer",role:"timer","aria-live":"off",text:fmtTime(s.remaining)}));
  const tb = el("div",{class:"timer-bar"});
  tb.append(el("div",{class:"fill",id:"mockTimerFill",style:"width:"+Math.max(0,s.remaining/(s.minutes*60)*100)+"%"}));
  tw.append(tb);
  header.append(tw);
  const right = el("div",{class:"sh-stats"});
  right.append(el("div",{class:"qcount",style:"margin:0",text:"Q "+(s.idx+1)+" of "+s.questions.length}));
  const flagged = s.flagged[s.idx];
  const flagBtn = el("button",{class:"icon-btn","aria-label":flagged?"Unmark":"Mark for review","aria-pressed":flagged?"true":"false",html:flagged?ICONS.flagFill:ICONS.flag,onclick:()=>{
    s.flagged[s.idx]=!s.flagged[s.idx]; showView("mock");
  }});
  right.append(flagBtn);
  header.append(right);
  sec.append(header);
  sec.append(el("h1",{class:"sr-only",text:"Mock exam in progress"}));

  const q = s.questions[s.idx];
  const card = el("div",{class:"qcard"});
  const meta = el("div",{class:"qmeta"});
  const unitInfo = el("div",{class:"unit"});
  unitInfo.append(el("span",{class:"dot",style:"background:var(--subject-"+sub.accent+")"}));
  unitInfo.append(el("span",{text:q.unit||"General"}));
  meta.append(unitInfo);
  if(q.source==="ai") meta.append(badge(sub.source==="ai"?"ai":"verify"));
  card.append(meta);
  card.append(el("div",{class:"qtext",text:q.question}));

  const optsWrap = el("div",{class:"options"});
  ["A","B","C","D"].forEach(letter=>{
    const sel = s.answers[s.idx]===letter;
    const ob = el("button",{class:"opt","aria-pressed":sel?"true":"false"});
    ob.append(el("span",{class:"ltoken",text:letter}));
    ob.append(el("span",{class:"otext",text:q.options[letter]}));
    ob.append(el("span",{class:"ricon"}));
    ob.append(el("span",{class:"otag"}));
    ob.addEventListener("click",()=>{ s.answers[s.idx]= (s.answers[s.idx]===letter? null : letter); showView("mock"); });
    optsWrap.append(ob);
  });
  card.append(optsWrap);
  sec.append(card);

  // navigator (laptop inline grid / portrait toggle sheet) — render inline wrapped grid for both; compact
  const answeredCount = s.answers.filter(a=>a!=null).length;
  const navToggle = el("button",{class:"btn-secondary questions-toggle","aria-expanded":"false",text:"Questions ("+answeredCount+"/"+s.questions.length+")"});
  const navGrid = el("div",{class:"navigator",hidden:true});
  s.questions.forEach((_,i)=>{
    const cls = ["nav-cell"];
    if(s.answers[i]!=null) cls.push("answered");
    if(i===s.idx) cls.push("current");
    if(s.flagged[i]) cls.push("flagged");
    const cell = el("button",{class:cls.join(" "),"aria-label":"Question "+(i+1)+(s.answers[i]!=null?", answered":"")+(s.flagged[i]?", flagged":""),text:String(i+1),onclick:()=>{ s.idx=i; showView("mock"); }});
    navGrid.append(cell);
  });
  navToggle.addEventListener("click",()=>{ const open=navGrid.hidden; navGrid.hidden=!open; navToggle.setAttribute("aria-expanded",open?"true":"false"); });
  sec.append(navToggle);
  sec.append(navGrid);

  // nav buttons
  const navBtns = el("div",{class:"mock-nav-btns"});
  const prev = el("button",{class:"btn-secondary",text:"Previous",disabled:s.idx===0?true:null,onclick:()=>{ if(s.idx>0){ s.idx--; showView("mock"); } }});
  navBtns.append(prev);
  if(s.idx>=s.questions.length-1){
    navBtns.append(el("button",{class:"btn-primary",text:"Review & submit",onclick:()=>confirmSubmitMock()}));
  } else {
    navBtns.append(el("button",{class:"btn-primary",text:"Next",onclick:()=>{ s.idx++; showView("mock"); }}));
  }
  sec.append(navBtns);
  return sec;
}
function confirmLeaveMock(){
  openConfirm({ title:"Leave the exam?", body:"Your progress in this exam will be lost.", confirm:"Leave", cancel:"Stay", danger:true, onConfirm:()=>{
    if(STATE.session && STATE.session.timerId) clearInterval(STATE.session.timerId);
    STATE.session=null; showView("home");
  }});
}
function confirmSubmitMock(){
  const s = STATE.session;
  const answered = s.answers.filter(a=>a!=null).length;
  openConfirm({ title:"Submit your exam?", body:"You've answered "+answered+" of "+s.questions.length+" questions. You can't change answers after this.", confirm:"Submit", cancel:"Keep going", danger:false, onConfirm:()=>submitMock() });
}
function submitMock(){
  const s = STATE.session;
  if(s.timerId) clearInterval(s.timerId);
  finalizeMock(false);
}
function autoSubmitMock(){
  const s = STATE.session;
  if(!s || s.submitted) return;
  toast("Time's up — here's your review.");
  finalizeMock(true);
}
function finalizeMock(auto){
  const s = STATE.session;
  if(s.submitted) return;
  s.submitted=true;
  if(s.timerId) clearInterval(s.timerId);
  // grade + record
  let correct=0;
  const items = s.questions.map((q,i)=>{
    const sel = s.answers[i];
    const isCorrect = sel===q.correct;
    if(isCorrect) correct++;
    if(sel!=null){ recordAnswer(s.subject, q.unit||"General", isCorrect); }
    return { q, selected:sel, correct:isCorrect, flagged:s.flagged[i] };
  });
  bumpDayStreak();
  saveProgress();
  STATE.mockReview = {
    subject:s.subject, items, correct, total:s.questions.length,
    timeUsed: s.minutes*60 - s.remaining,
  };
  STATE.reviewFilter="all";
  showView("review");
}

/* ============================ SUMMARY ============================ */
function weakestUnit(answers){
  const map={};
  for(const a of answers){
    const u=a.q.unit||"General";
    if(!map[u]) map[u]={answered:0,correct:0};
    map[u].answered++; if(a.correct) map[u].correct++;
  }
  let worst=null, worstAcc=2;
  for(const u of Object.keys(map)){
    const m=map[u];
    const acc=m.correct/m.answered;
    if(acc<worstAcc){ worstAcc=acc; worst=u; }
  }
  return (worst && worstAcc<1) ? worst : null;
}
function renderSummary(){
  const s = STATE.session;
  const sec = el("section",{role:"region","aria-label":"Session summary"});
  const total = s.answers.length;
  const correct = s.correct;
  const acc = total?Math.round(correct/total*100):0;
  let head;
  if(acc>=90) head="Excellent set.";
  else if(acc>=70) head="Strong work.";
  else if(acc>=50) head="Good practice — keep going.";
  else head="Tough set — that's how you learn.";
  const timeUsed = Math.round((Date.now()-s.startTime)/1000);

  const panel = el("div",{class:"summary-panel"});
  panel.append(el("h1",{class:"summary-head",text:head}));
  panel.append(el("div",{class:"summary-score",text:correct+" / "+total}));
  panel.append(el("div",{class:"summary-acc",text:acc+"% accuracy"}));

  const weak = total>=CONFIG.SUMMARY_WEAK_MIN ? weakestUnit(s.answers) : null;
  const tiles = el("div",{class:"tiles-row"});
  function tile(v,l){ return el("div",{class:"stat-tile"},[ el("div",{class:"stat-value",text:v}), el("div",{class:"stat-label",text:l}) ]); }
  tiles.append(tile(fmtTime(timeUsed),"Time"));
  tiles.append(tile(String(s.bestStreak),"Best streak"));
  tiles.append(tile(weak?truncate(weak,14):"—","Weakest unit"));
  panel.append(tiles);

  if(weak){
    const wc = el("div",{class:"weak-callout"});
    wc.append(el("p",{text:"Spend a little time on "+weak+" — that's where the misses clustered."}));
    wc.append(el("button",{class:"btn-secondary",text:"Practice "+truncate(weak,18),onclick:()=>{ STATE.subject=s.subject; STATE.unit=weak; STATE.mode="practice"; showView("setup"); }}));
    panel.append(wc);
  } else if(total<CONFIG.SUMMARY_WEAK_MIN){
    panel.append(el("p",{class:"helper",style:"text-align:center",text:"Keep practicing to spot your weak units."}));
  }

  const acts = el("div",{class:"summary-actions"});
  acts.append(el("button",{class:"btn-primary",text:"Practice again",onclick:()=>{ STATE.subject=s.subject; STATE.unit=s.unit; STATE.difficulty=s.difficulty; STATE.mode="practice"; STATE.session=null; showView("setup"); }}));
  acts.append(el("button",{class:"btn-secondary",text:"Back to subjects",onclick:()=>{ STATE.session=null; showView("home"); }}));
  panel.append(acts);
  sec.append(panel);
  return sec;
}
function truncate(s,n){ s=String(s); return s.length>n ? s.slice(0,n-1)+"…" : s; }

/* ============================ MOCK REVIEW ============================ */
function renderReview(){
  const r = STATE.mockReview;
  if(!r){ showView("home"); return el("section",{role:"region"}); }
  const sub = SUBJECT_BY_ID[r.subject];
  const sec = el("section",{role:"region","aria-label":"Mock exam review"});
  sec.append(el("h1",{class:"h1",text:"Your results"}));

  const acc = r.total?Math.round(r.correct/r.total*100):0;
  const weak = weakestUnit(r.items.filter(i=>i.selected!=null));
  const band = el("div",{class:"summary-band"});
  band.append(el("div",{class:"sb-score",text:r.correct+" / "+r.total}));
  band.append(el("div",{class:"summary-acc",text:acc+"% accuracy"}));
  const tiles = el("div",{class:"tiles-row"});
  function tile(v,l){ return el("div",{class:"stat-tile"},[ el("div",{class:"stat-value",text:v}), el("div",{class:"stat-label",text:l}) ]); }
  tiles.append(tile(fmtTime(r.timeUsed),"Time"));
  tiles.append(tile(acc+"%","Accuracy"));
  tiles.append(tile(weak?truncate(weak,14):"—","Weakest unit"));
  band.append(tiles);
  sec.append(band);

  // filter chips
  const filters=[["all","All"],["incorrect","Incorrect"],["skipped","Skipped"],["flagged","Flagged"]];
  const frow = el("div",{class:"filter-row",role:"radiogroup","aria-label":"Filter review"});
  const fbtns=[];
  filters.forEach(([id,lbl])=>{
    const checked=STATE.reviewFilter===id;
    const c=el("button",{class:"filter-chip",role:"radio","aria-checked":checked?"true":"false",tabindex:checked?"0":"-1",text:lbl,onclick:()=>{ STATE.reviewFilter=id; showView("review"); }});
    fbtns.push(c); frow.append(c);
  });
  sec.append(frow);

  // filtered list
  let items = r.items.map((it,i)=>({...it,num:i+1}));
  if(STATE.reviewFilter==="incorrect") items=items.filter(i=>i.selected!=null && !i.correct);
  else if(STATE.reviewFilter==="skipped") items=items.filter(i=>i.selected==null);
  else if(STATE.reviewFilter==="flagged") items=items.filter(i=>i.flagged);

  if(items.length===0){
    sec.append(el("div",{class:"empty-block"},[ el("p",{class:"eb-body",text:"Nothing here — you didn't miss any. Nice."}) ]));
  } else {
    for(const it of items){
      sec.append(buildReviewItem(it, sub));
    }
  }

  const acts = el("div",{class:"review-actions"});
  acts.append(el("button",{class:"btn-primary",text:"Back to subjects",onclick:()=>{ STATE.mockReview=null; STATE.session=null; showView("home"); }}));
  const wrongOnes = r.items.filter(i=>i.selected!=null && !i.correct);
  if(wrongOnes.length>0){
    acts.append(el("button",{class:"btn-secondary",text:"Retry weak ones",onclick:()=>retryWeak(wrongOnes, r.subject)}));
  }
  sec.append(acts);
  return sec;
}
function buildReviewItem(it, sub){
  const q = it.q;
  const card = el("div",{class:"review-item"});
  const head = el("div",{class:"ri-head"});
  head.append(el("span",{class:"ri-q",text:"Q"+it.num}));
  let tagClass = it.selected==null ? "skipped" : (it.correct?"correct":"incorrect");
  let tagText = it.selected==null ? "Skipped" : (it.correct?"Correct":"Incorrect");
  head.append(el("span",{class:"result-tag "+tagClass,text:tagText}));
  if(q.source==="ai") head.append(badge(sub.source==="ai"?"ai":"verify"));
  card.append(head);
  card.append(el("div",{class:"ri-qtext",text:q.question}));
  const ropts = el("div",{class:"ropts"});
  ["A","B","C","D"].forEach(letter=>{
    const ro = el("div",{class:"ropt"});
    if(letter===q.correct) ro.classList.add("correct");
    else if(letter===it.selected) ro.classList.add("incorrect");
    ro.append(el("span",{class:"ltoken",text:letter}));
    ro.append(el("span",{class:"otext",text:q.options[letter]}));
    if(letter===q.correct) ro.append(el("span",{class:"otag",text:"Correct answer"}));
    else if(letter===it.selected) ro.append(el("span",{class:"otag",text:"Your answer"}));
    ropts.append(ro);
  });
  card.append(ropts);
  const ex = el("div",{class:"explain"+(it.correct?"":" wrong")});
  ex.append(el("div",{class:"why",text:"Why"}));
  if(q.source==="ai") ex.append(el("div",{class:"ai-note",text:"AI-generated — verify against your notes."}));
  ex.append(el("div",{class:"body",text:q.explanation}));
  card.append(ex);
  return card;
}
function retryWeak(wrongOnes, subjectId){
  const sub = SUBJECT_BY_ID[subjectId];
  STATE.session = {
    type:"practice", subject:subjectId, unit:"__all__", difficulty:STATE.difficulty,
    questions: shuffle(wrongOnes.map(w=>w.q)).slice(0,CONFIG.PRACTICE_CAP),
    idx:0, answers:[], correct:0, streak:0, bestStreak:0, startTime:Date.now(),
    aiMode:false, graded:false, selected:null, loading:false, error:null,
  };
  STATE.subject=subjectId;
  STATE.mockReview=null;
  showView("practice");
}

/* ============================ DASHBOARD ============================ */
function renderDashboard(){
  const sec = el("section",{role:"region","aria-label":"Your progress"});
  sec.append(backRow("Back to subjects",()=>showView("home")));
  sec.append(el("h1",{class:"h1",text:"Your progress"}));

  const ov = overallStats();
  const tiles = el("div",{class:"overview-tiles"});
  function tile(v,l,muted){ return el("div",{class:"stat-tile"},[ el("div",{class:"stat-value"+(muted?" muted":""),text:v}), el("div",{class:"stat-label",text:l}) ]); }
  const any = ov.answered>0;
  tiles.append(tile(any?String(ov.answered):"0","Total answered",!any));
  tiles.append(tile(any?ov.accuracy+"%":"—%","Overall accuracy",!any));
  tiles.append(tile(any?String(PROGRESS.streak.count):"0","Day streak",!any));
  tiles.append(tile(any?String(PROGRESS.streak.best):"0","Best streak",!any));
  sec.append(tiles);

  if(!any){
    sec.append(el("div",{class:"empty-block"},[
      el("div",{class:"eb-icon",html:ICONS.chart}),
      el("div",{class:"eb-head",text:"No progress yet"}),
      el("div",{class:"eb-body",text:"Answer a few questions and your accuracy will show up here."}),
      el("button",{class:"btn-primary",style:"max-width:280px;margin:0 auto",text:"Start practicing",onclick:()=>showView("home")}),
    ]));
    return sec;
  }

  for(const sub of SUBJECTS){
    const st = subjectStats(sub.id);
    const row = el("div",{class:"subj-row"});
    const expanded = STATE.dashboardSubject===sub.id;
    const headBtn = el("button",{class:"subj-row-head","aria-expanded":expanded?"true":"false",onclick:()=>{ STATE.dashboardSubject = expanded?null:sub.id; showView("dashboard"); }});
    headBtn.append(el("span",{class:"dot",style:"background:var(--subject-"+sub.accent+")"}));
    headBtn.append(el("span",{class:"sname",text:sub.name}));
    if(st.answered>0){
      const bar = el("div",{class:"subj-bar"});
      bar.append(el("div",{class:"fill",style:"width:"+st.accuracy+"%;background:var(--subject-"+sub.accent+")"}));
      headBtn.append(bar);
      headBtn.append(el("span",{class:"subj-trail",text:st.accuracy+"% · "+st.answered+" answered"}));
    } else {
      headBtn.append(el("div",{class:"untouched-bar"}));
      headBtn.append(el("span",{class:"subj-trail",text:"Not started"}));
    }
    row.append(headBtn);

    if(expanded && st.answered>0){
      const unitsWrap = el("div",{class:"subj-units"});
      const subData = PROGRESS.subjects[sub.id];
      const unitNames = subData ? Object.keys(subData.units) : [];
      // order: curriculum order if available
      const order = unitsFor(sub.id);
      const ordered = order.filter(u=>unitNames.includes(u)).concat(unitNames.filter(u=>!order.includes(u)));
      for(const u of ordered){
        const m = subData.units[u];
        if(!m || m.answered===0) continue;
        const acc = Math.round(m.correct/m.answered*100);
        const weak = (m.answered>=CONFIG.WEAK_UNIT_MIN_ANSWERS) && (m.correct/m.answered < CONFIG.WEAK_UNIT_THRESHOLD);
        const us = el("div",{class:"unit-stat"});
        const uname = el("span",{class:"uname"});
        if(weak){ uname.append(el("span",{class:"warn-dot","aria-hidden":"true"})); uname.append(el("span",{class:"sr-only",text:"Needs work. "})); }
        uname.append(el("span",{text:u,title:u}));
        us.append(uname);
        const mb = el("div",{class:"mini-bar"+(weak?" weak":"")});
        mb.append(el("div",{class:"fill",style:"width:"+acc+"%;background:var(--subject-"+sub.accent+")"}));
        us.append(mb);
        us.append(el("span",{class:"ut",text:acc+"% ("+m.correct+"/"+m.answered+")"}));
        us.append(el("button",{class:"upract",text:"Practice",onclick:()=>{ STATE.subject=sub.id; STATE.unit=u; STATE.mode="practice"; showView("setup"); }}));
        unitsWrap.append(us);
      }
      row.append(unitsWrap);
    } else if(expanded){
      const w = el("div",{class:"subj-units"});
      w.append(el("p",{class:"helper",text:"Not started"}));
      row.append(w);
    }
    sec.append(row);
  }
  return sec;
}

/* ============================ MODAL INFRASTRUCTURE ============================ */
let activeModal=null, lastFocused=null;
function trapFocus(container, e){
  const focusables = container.querySelectorAll('button,[href],input,select,textarea,[tabindex]:not([tabindex="-1"])');
  const list = Array.prototype.filter.call(focusables, n=>!n.disabled && n.offsetParent!==null);
  if(list.length===0) return;
  const first=list[0], last=list[list.length-1];
  if(e.shiftKey && document.activeElement===first){ e.preventDefault(); last.focus(); }
  else if(!e.shiftKey && document.activeElement===last){ e.preventDefault(); first.focus(); }
}
function closeModal(){
  if(activeModal){ activeModal.remove(); activeModal=null; }
  document.removeEventListener("keydown",modalKeydown,true);
  if(lastFocused && document.body.contains(lastFocused)) lastFocused.focus();
  lastFocused=null;
}
function modalKeydown(e){
  if(!activeModal) return;
  if(e.key==="Escape"){ e.preventDefault(); const c=activeModal._onCancel; closeModal(); if(c)c(); }
  else if(e.key==="Tab"){ trapFocus(activeModal._panel, e); }
}
function openConfirm(opts){
  lastFocused = document.activeElement;
  const scrim = el("div",{class:"scrim"});
  const titleId="confirmTitle-"+Date.now();
  const dialog = el("div",{class:"dialog",role:"dialog","aria-modal":"true","aria-labelledby":titleId});
  dialog.append(el("div",{class:"d-title",id:titleId,text:opts.title}));
  dialog.append(el("div",{class:"d-body",text:opts.body}));
  const actions = el("div",{class:"d-actions"});
  const cancelBtn = el("button",{class:"d-cancel",text:opts.cancel,onclick:()=>{ closeModal(); if(opts.onCancel)opts.onCancel(); }});
  const confirmBtn = el("button",{class:"d-confirm"+(opts.danger?" danger":""),text:opts.confirm,onclick:()=>{ closeModal(); if(opts.onConfirm)opts.onConfirm(); }});
  // destructive: focus safest (cancel). non-destructive submit: focus confirm.
  actions.append(cancelBtn,confirmBtn);
  dialog.append(actions);
  scrim.append(dialog);
  scrim.addEventListener("click",e=>{ if(e.target===scrim){ closeModal(); if(opts.onCancel)opts.onCancel(); } });
  document.body.append(scrim);
  activeModal=scrim; activeModal._panel=dialog; activeModal._onCancel=opts.onCancel||null;
  document.addEventListener("keydown",modalKeydown,true);
  requestAnimationFrame(()=>{ (opts.danger?cancelBtn:confirmBtn).focus(); });
}

/* ============================ BACKUP / RESTORE ============================ */
const BACKUP_APP_ID = "exam-prep";
const BACKUP_VERSION = 1;

// Build the backup object from current localStorage state. Progress is the parsed
// stored object (or null); keys/theme/provider are raw strings (or null).
function buildBackup(){
  let progress = null;
  const rawProgress = safeGet(STORAGE.PROGRESS);
  if(rawProgress!=null){
    try{
      const p = JSON.parse(rawProgress);
      if(p && typeof p==="object") progress = p;
    }catch(e){ progress = null; }
  }
  const theme = safeGet(STORAGE.THEME);
  const provider = safeGet(STORAGE.PROVIDER);
  const geminiKey = safeGet(STORAGE.GEMINI_KEY);
  const groqKey = safeGet(STORAGE.GROQ_KEY);
  return {
    app: BACKUP_APP_ID,
    version: BACKUP_VERSION,
    exportedAt: new Date().toISOString(),
    data: {
      progress: progress,
      theme: (typeof theme==="string") ? theme : null,
      provider: (typeof provider==="string") ? provider : null,
      geminiKey: (typeof geminiKey==="string") ? geminiKey : null,
      groqKey: (typeof groqKey==="string") ? groqKey : null,
    },
  };
}
function buildBackupJSON(){ return JSON.stringify(buildBackup(), null, 2); }

function backupFilename(){
  const d = new Date();
  const pad = n=>String(n).padStart(2,"0");
  return "exam-prep-backup-"+d.getFullYear()+"-"+pad(d.getMonth()+1)+"-"+pad(d.getDate())+".json";
}

// Trigger a file download via Blob + temporary <a download>. Returns true if the
// attempt was made without throwing, false otherwise (caller falls back to copy/paste).
function downloadBackup(json){
  try{
    const blob = new Blob([json], { type:"application/json" });
    const url = URL.createObjectURL(blob);
    const a = el("a",{ href:url, download:backupFilename() });
    a.style.display="none";
    document.body.append(a);
    a.click();
    setTimeout(()=>{ try{ a.remove(); URL.revokeObjectURL(url); }catch(e){} }, 0);
    return true;
  }catch(e){ return false; }
}

// Copy text to clipboard. Async clipboard first (https/secure), then a synchronous
// textarea select + execCommand fallback that works on file://. Returns a Promise<bool>.
function copyBackupText(text, sourceTextarea){
  const fallback = ()=>{
    try{
      let ta = sourceTextarea;
      let temp = null;
      if(!ta){
        temp = el("textarea");
        temp.value = text;
        temp.style.position="fixed"; temp.style.opacity="0"; temp.style.pointerEvents="none";
        document.body.append(temp);
        ta = temp;
      }
      ta.focus();
      ta.select();
      ta.setSelectionRange(0, text.length);
      const ok = document.execCommand("copy");
      if(temp) temp.remove();
      return !!ok;
    }catch(e){ return false; }
  };
  try{
    if(navigator.clipboard && typeof navigator.clipboard.writeText==="function"){
      return navigator.clipboard.writeText(text).then(()=>true, ()=>fallback());
    }
  }catch(e){}
  return Promise.resolve(fallback());
}

// Validate a parsed backup object and return a clean { progress, theme, provider,
// geminiKey, groqKey } where only known, type-valid fields are present. Throws on a
// structurally invalid / foreign backup. Unknown fields are ignored; absent optional
// fields are simply omitted (so they don't overwrite existing values on restore).
function validateBackup(obj){
  if(!obj || typeof obj!=="object" || Array.isArray(obj)) throw new Error("not an object");
  if(obj.app !== BACKUP_APP_ID) throw new Error("wrong app");
  const data = obj.data;
  if(!data || typeof data!=="object" || Array.isArray(data)) throw new Error("no data");
  const out = {};
  // progress: object or null (absent => leave existing untouched)
  if("progress" in data){
    const pg = data.progress;
    if(pg===null || (typeof pg==="object" && !Array.isArray(pg))) out.progress = pg;
    else throw new Error("bad progress");
  }
  // theme: one of light|dark|system, or null
  if("theme" in data && data.theme!==null){
    if(data.theme==="light"||data.theme==="dark"||data.theme==="system") out.theme = data.theme;
    else throw new Error("bad theme");
  }
  // provider: one of groq|gemini, or null
  if("provider" in data && data.provider!==null){
    if(data.provider==="groq"||data.provider==="gemini") out.provider = data.provider;
    else throw new Error("bad provider");
  }
  // keys: string or null. null/absent => do NOT wipe existing key.
  if("geminiKey" in data && data.geminiKey!==null){
    if(typeof data.geminiKey==="string") out.geminiKey = data.geminiKey;
    else throw new Error("bad geminiKey");
  }
  if("groqKey" in data && data.groqKey!==null){
    if(typeof data.groqKey==="string") out.groqKey = data.groqKey;
    else throw new Error("bad groqKey");
  }
  return out;
}

// Apply a validated backup to localStorage + live state. Only fields present in
// `clean` are written; absent fields are left as-is.
function applyBackup(clean){
  if("progress" in clean){
    if(clean.progress===null){ safeRemove(STORAGE.PROGRESS); }
    else{ try{ safeSet(STORAGE.PROGRESS, JSON.stringify(clean.progress)); }catch(e){} }
    loadProgress(); // re-parse + sanitize into PROGRESS
  }
  if("theme" in clean){ setTheme(clean.theme); }
  if("provider" in clean){ setProvider(clean.provider); }
  if("geminiKey" in clean){ safeSet(STORAGE.GEMINI_KEY, clean.geminiKey); }
  if("groqKey" in clean){ safeSet(STORAGE.GROQ_KEY, clean.groqKey); }
}

/* ============================ SETTINGS ============================ */
let settingsKeyVisible=false;
function openSettings(focusKey){
  lastFocused = document.activeElement;
  settingsKeyVisible=false;
  const scrim = el("div",{class:"sheet-scrim"});
  const titleId="settingsTitle";
  const sheet = el("div",{class:"sheet",role:"dialog","aria-modal":"true","aria-labelledby":titleId});
  sheet.append(el("div",{class:"sheet-handle","aria-hidden":"true"}));
  const head = el("div",{class:"sheet-head"});
  head.append(el("div",{class:"s-title",id:titleId,text:"Settings"}));
  head.append(el("button",{class:"icon-btn","aria-label":"Close settings",html:ICONS.close,onclick:()=>closeModal()}));
  sheet.append(head);

  // APPEARANCE
  const appearance = el("div",{class:"set-section"});
  appearance.append(el("div",{class:"set-label",text:"Theme"}));
  const seg = el("div",{class:"seg3",role:"radiogroup","aria-label":"Theme"});
  [["light","Light"],["dark","Dark"],["system","System"]].forEach(([id,lbl])=>{
    const checked = themePref===id;
    const b = el("button",{role:"radio","aria-checked":checked?"true":"false",tabindex:checked?"0":"-1",text:lbl,onclick:()=>{ setTheme(id); seg.querySelectorAll("button").forEach(x=>{ const on=x===b; x.setAttribute("aria-checked",on?"true":"false"); x.setAttribute("tabindex",on?"0":"-1"); }); }});
    seg.append(b);
  });
  appearance.append(seg);
  sheet.append(appearance);

  // AI PROVIDER + KEY
  const aiSection = el("div",{class:"set-section"});
  aiSection.append(el("div",{class:"set-label",text:"AI provider"}));
  const provSeg = el("div",{class:"seg3",role:"radiogroup","aria-label":"AI provider"});
  [["groq","Groq"],["gemini","Gemini"]].forEach(([id,lbl])=>{
    const checked = getProvider()===id;
    const b = el("button",{role:"radio","aria-checked":checked?"true":"false",tabindex:checked?"0":"-1",text:lbl,onclick:()=>{
      setProvider(id);
      provSeg.querySelectorAll("button").forEach(x=>{ const on=x===b; x.setAttribute("aria-checked",on?"true":"false"); x.setAttribute("tabindex",on?"0":"-1"); });
      renderKeyArea();
    }});
    provSeg.append(b);
  });
  aiSection.append(provSeg);

  const keyLabel = el("div",{class:"set-label",style:"margin-top:var(--sp-3)"});
  aiSection.append(keyLabel);
  const keyArea = el("div");
  function renderKeyArea(){
    const prov = PROVIDERS[getProvider()];
    keyLabel.textContent = prov.label+" API key";
    clear(keyArea);
    const key = getKey(prov.id);
    if(key){
      const last4 = key.slice(-4);
      const row = el("div",{class:"key-saved-row"});
      row.append(el("span",{text:"Key saved ••••"+last4}));
      row.append(el("button",{class:"key-remove",text:"Remove key",onclick:()=>{ safeRemove(prov.storeKey); toast("Key removed."); renderKeyArea(); }}));
      keyArea.append(row);
    } else {
      keyArea.append(el("p",{class:"key-helper",text:"Add a free "+prov.label+" key to unlock unlimited AI questions. The curated bank works without one."}));
      const inputRow = el("div",{class:"key-inputrow"});
      const input = el("input",{class:"key-input",type:settingsKeyVisible?"text":"password",inputmode:"text",autocomplete:"off",autocapitalize:"off",spellcheck:"false",placeholder:"Paste your key","aria-label":prov.label+" API key"});
      const toggleBtn = el("button",{class:"key-toggle",text:settingsKeyVisible?"Hide":"Show",onclick:()=>{ settingsKeyVisible=!settingsKeyVisible; input.type=settingsKeyVisible?"text":"password"; toggleBtn.textContent=settingsKeyVisible?"Hide":"Show"; }});
      inputRow.append(input,toggleBtn);
      keyArea.append(inputRow);
      const saveBtn = el("button",{class:"btn-primary set-save-btn",text:"Save key",disabled:true});
      input.addEventListener("input",()=>{ saveBtn.disabled = input.value.trim()===""; });
      saveBtn.addEventListener("click",()=>{
        const v = input.value.trim();
        if(!v) return;
        if(!safeSet(prov.storeKey,v)){ const er=el("p",{class:"set-error",text:"Couldn't save to this device's storage."}); keyArea.append(er); return; }
        toast("Key saved."); renderKeyArea();
      });
      keyArea.append(saveBtn);
      if(focusKey){ requestAnimationFrame(()=>input.focus()); focusKey=false; }
    }
    clear(getLine);
    getLine.append(el("p",{class:"key-getline",text:prov.getLine}));
  }
  aiSection.append(keyArea);
  aiSection.append(el("p",{class:"key-helper",style:"margin-top:var(--sp-3)",text:"Your key stays on this device. It's only sent to the selected AI provider when generating AI questions."}));
  const getLine = el("div");
  aiSection.append(getLine);
  renderKeyArea();
  sheet.append(aiSection);

  // DATA
  const data = el("div",{class:"set-section"});
  data.append(el("div",{class:"set-label",text:"Data"}));
  data.append(el("button",{class:"btn-danger-outline",text:"Reset progress",onclick:()=>{
    openConfirm({
      title:"Reset all progress?",
      body:"This clears your scores, accuracy, streaks, and weak-unit history on this device. Your theme and API key are kept. This can't be undone.",
      confirm:"Reset", cancel:"Cancel", danger:true,
      onConfirm:()=>{
        PROGRESS = { subjects:{}, streak:{ count:0, best:0, lastDay:null } };
        safeRemove(STORAGE.PROGRESS);
        toast("Progress reset.");
        if(STATE.view==="home"||STATE.view==="dashboard") showView(STATE.view);
      },
    });
  }}));

  // BACKUP / RESTORE
  data.append(el("div",{class:"backup-sublabel",style:"margin-top:var(--sp-5)",text:"Back up your progress & keys"}));

  // Backup textarea (the universal, CSP-safe fallback) — populated on demand.
  const backupArea = el("textarea",{class:"backup-area",readonly:true,spellcheck:"false","aria-label":"Backup data (JSON)",style:"display:none"});

  const backupRow = el("div",{class:"backup-row"});
  const copyBtn = el("button",{class:"btn-secondary",text:"Copy",style:"display:none"});
  backupRow.append(el("button",{class:"btn-primary",text:"Back up progress",onclick:()=>{
    const json = buildBackupJSON();
    backupArea.value = json;
    backupArea.style.display = "block";
    copyBtn.style.display = "";
    const downloaded = downloadBackup(json);
    toast(downloaded ? "Backup downloaded" : "Backup ready below — copy it to save.");
  }}));
  copyBtn.addEventListener("click",()=>{
    const text = backupArea.value;
    if(!text){ toast("Tap “Back up progress” first."); return; }
    copyBackupText(text, backupArea).then(ok=>{
      toast(ok ? "Backup copied" : "Couldn't copy — select the text and copy manually.", ok?undefined:"error");
    });
  });
  backupRow.append(copyBtn);
  data.append(backupRow);
  data.append(backupArea);
  data.append(el("p",{class:"backup-note",text:"This backup includes your saved AI key(s) in plain text — keep the file private and don't share it."}));

  // Restore
  data.append(el("div",{class:"backup-sublabel",text:"Restore from backup"}));
  const restoreError = el("p",{class:"set-error",style:"display:none",role:"alert"});

  function showRestoreError(msg){
    restoreError.textContent = msg;
    restoreError.style.display = "block";
  }
  function clearRestoreError(){
    restoreError.textContent = "";
    restoreError.style.display = "none";
  }

  // Validate raw JSON text, then gate the overwrite behind the confirm modal.
  function attemptRestore(rawText){
    clearRestoreError();
    if(typeof rawText!=="string" || rawText.trim()===""){
      showRestoreError("Paste a backup or choose a file first.");
      return;
    }
    let parsed, clean;
    try{
      parsed = JSON.parse(rawText);
      clean = validateBackup(parsed);
    }catch(e){
      showRestoreError("That backup file couldn't be read.");
      return;
    }
    openConfirm({
      title:"Restore from backup?",
      body:"Restore will replace your current progress and saved keys. Continue?",
      confirm:"Restore", cancel:"Cancel", danger:true,
      onConfirm:()=>{
        try{ applyBackup(clean); }
        catch(e){ toast("That backup file couldn't be read.","error"); return; }
        toast("Progress restored");
        // Re-render so streaks/progress/keys reflect immediately.
        if(STATE.view==="home"||STATE.view==="dashboard") showView(STATE.view);
        else showView("home");
        // The confirm dialog already closed itself; the underlying settings sheet is still
        // mounted. Tear it down cleanly, then reopen fresh so theme/provider/keys show updated state.
        try{ scrim.remove(); }catch(e){}
        document.removeEventListener("keydown",modalKeydown,true);
        activeModal=null;
        openSettings(false);
      },
    });
  }

  const fileInput = el("input",{type:"file",accept:"application/json,.json",class:"backup-file","aria-label":"Choose a backup file"});
  fileInput.addEventListener("change",()=>{
    clearRestoreError();
    const f = fileInput.files && fileInput.files[0];
    if(!f) return;
    const reader = new FileReader();
    reader.onload = ()=>{
      const txt = (typeof reader.result==="string") ? reader.result : "";
      attemptRestore(txt);
      fileInput.value = ""; // allow re-selecting the same file
    };
    reader.onerror = ()=>{ showRestoreError("That backup file couldn't be read."); fileInput.value=""; };
    try{ reader.readAsText(f); }
    catch(e){ showRestoreError("That backup file couldn't be read."); fileInput.value=""; }
  });
  data.append(fileInput);

  const restoreArea = el("textarea",{class:"backup-area",spellcheck:"false",placeholder:"…or paste your backup JSON here","aria-label":"Paste backup data (JSON)"});
  data.append(restoreArea);
  const restoreBtn = el("button",{class:"btn-secondary",style:"margin-top:var(--sp-3)",text:"Restore",onclick:()=>{ attemptRestore(restoreArea.value); }});
  data.append(restoreBtn);
  data.append(restoreError);

  sheet.append(data);

  // ABOUT
  const about = el("div",{class:"set-section"});
  about.append(el("p",{class:"about-line",text:"Offline study app · Grade 12 Natural Science"}));
  about.append(el("p",{class:"about-line",style:"margin-top:var(--sp-1)",text:"Version 1.0"}));
  sheet.append(about);

  scrim.append(sheet);
  scrim.addEventListener("click",e=>{ if(e.target===scrim) closeModal(); });
  document.body.append(scrim);
  activeModal=scrim; activeModal._panel=sheet; activeModal._onCancel=null;
  document.addEventListener("keydown",modalKeydown,true);
  if(!focusKey) requestAnimationFrame(()=>{ sheet.querySelector('[aria-checked="true"]').focus(); });
}

/* ============================ INIT ============================ */
function init(){
  initTheme();
  loadProgress();
  $("gearBtn").addEventListener("click",()=>openSettings(false));
  showView("home");
  if(progressCorrupt){
    toast("Couldn't read your saved progress, so it's been reset. Your questions are unaffected.","error");
  }
}
init();
</script>
</body>
</html>
