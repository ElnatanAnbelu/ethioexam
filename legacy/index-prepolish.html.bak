/* ===== Compact-bank hydration =====
   Each compact row {i,g,u,d,t,q,o[4],c,e} -> the full object the app uses.
   Defensive: malformed rows (missing fields / o.length!=4 / c out of 0..3 /
   off-taxonomy unit) are skipped, never thrown. */
const SUBJ_TAXO_KEY = { Physics:"Physics", Chemistry:"Chemistry", Biology:"Biology", Mathematics:"Mathematics" };
function hydrateRow(row, subject){
  if(!row || typeof row!=="object") return null;
  const { i, g, u, d, t, q, o, c, e } = row;
  if(typeof i!=="string" || !i) return null;
  if(![9,10,11,12].includes(g)) return null;
  if(typeof u!=="string" || !u) return null;
  if(typeof q!=="string" || !q) return null;
  if(!Array.isArray(o) || o.length!==4) return null;
  if(o.some(x=>typeof x!=="string" || !x.length)) return null;
  if(!(Number.isInteger(c) && c>=0 && c<=3)) return null;
  if(typeof e!=="string") return null;
  const tax = UNIT_TAXONOMY[subject];
  if(!tax || !tax[g] || !tax[g].includes(u)) return null;
  return {
    id:i, subject:subject, grade:g, unit:u,
    difficulty:(typeof d==="string"&&d)?d:"medium",
    type:(typeof t==="string"&&t)?t:"conceptual",
    question:q, options:{ A:o[0], B:o[1], C:o[2], D:o[3] },
    correct:["A","B","C","D"][c], explanation:e, source:"curated"
  };
}
function hydrateBank(arr, subject){
  const out=[];
  if(!Array.isArray(arr)) return out;
  for(const row of arr){ const h=hydrateRow(row, subject); if(h) out.push(h); }
  return out;
}

const CURATED_BANK = [].concat(
  hydrateBank(typeof window.QB_PHYSICS!=="undefined"?window.QB_PHYSICS:[], "Physics"),
  hydrateBank(typeof window.QB_CHEMISTRY!=="undefined"?window.QB_CHEMISTRY:[], "Chemistry"),
  hydrateBank(typeof window.QB_BIOLOGY!=="undefined"?window.QB_BIOLOGY:[], "Biology"),
  hydrateBank(typeof window.QB_MATH!=="undefined"?window.QB_MATH:[], "Mathematics")
);


